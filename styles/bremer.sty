% moderncv-bremer style layer
% Keep this file free of personal data.

\moderncvstyle{classic}
\moderncvcolor{black}

\usepackage[scale=0.82]{geometry}
\setlength{\hintscolumnwidth}{3.2cm}

\usepackage[ngerman]{babel}
\usepackage{enumitem}
\usepackage{xcolor}
\usepackage{microtype}
\usepackage{fontawesome5}

\definecolor{bremeraccent}{HTML}{222222}
\definecolor{bremermuted}{HTML}{666666}

\setlist[itemize]{
  topsep=0.2em,
  itemsep=0.15em,
  parsep=0em,
  leftmargin=1.2em
}

\newcommand{\cvprofile}[1]{%
  \section{Profil}%
  \cvitem{}{#1}%
}

\newcommand{\cvskills}[2]{%
  \cvitem{\textbf{#1}}{#2}%
}

\newcommand{\cvjob}[6]{%
  \cventry{#1}{#2}{#3}{#4}{}{%
    #5%
    \ifx\relax#6\relax\else\vspace{0.2em}\newline\textcolor{bremermuted}{\small #6}\fi%
  }%
}

\newcommand{\cvproject}[3]{%
  \cvitem{\textbf{#1}}{#2\ifx\relax#3\relax\else\newline\textcolor{bremermuted}{\small #3}\fi}%
}

\newcommand{\tech}[1]{\textcolor{bremermuted}{\small #1}}
