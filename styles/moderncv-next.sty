\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{moderncv-next}[2026/06/26 Thin extensions for moderncv]

\RequirePackage{enumitem}

\newcommand{\cvnextprofile}[1]{%
  \cvitem{}{#1}
}

\newenvironment{cvnextbullets}{%
  \begin{itemize}[leftmargin=*, itemsep=0.15em, topsep=0.2em]
}{%
  \end{itemize}
}

\newcommand{\cvnextbullet}[1]{%
  \item #1
}
